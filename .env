# --- GLOBAL CONFIGS ---
# Uygulama Versiyonu
APP_VERSION=1.0.0

# --- PORTS (Varsayılan Portlar) ---
DISCOVERY_PORT=8761
GATEWAY_PORT=8762
USER_PORT=9093 # Prometheus (9090) ile çakışmaması için 9093 yaptık
PROJECT_PORT=9091
TASK_PORT=9092
ZIPKIN_PORT=9411
DB_PORT=5433 # host port; 5432 often taken by another local Postgres

# --- HOSTS (Localhost vs Docker) ---
# Docker Compose ile çalıştırırken bu değerler otomatik ezilecek.
# IDE ile çalıştırırken burası 'localhost' kalmalı.
DISCOVERY_HOST=localhost
GATEWAY_HOST=localhost
USER_HOST=localhost
PROJECT_HOST=localhost
TASK_HOST=localhost
ZIPKIN_HOST=localhost
DB_HOST=localhost

# --- DATABASE CREDENTIALS ---
DB_USERNAME=postgres
DB_PASSWORD=postgres

# --- DOCKER COMPOSE OVERRIDES ---
# Consumed by docker-compose/services.yml (via root compose.yaml). The *_HOST
# values above are ignored under compose — service hostnames are set explicitly.
NOTIFICATION_PORT=9094

# RabbitMQ (event bus)
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_PORT=5673
RABBITMQ_MGMT_PORT=15673

# Grafana on 3030 so the Next.js UI can keep 3000
GRAFANA_PORT=3030

# JWT signing secret — HS256 needs >= 32 chars. Override in prod: `openssl rand -hex 48`
JWT_SECRET=issue-tracker-jwt-secret-key-must-be-at-least-256-bits-long-for-hs256