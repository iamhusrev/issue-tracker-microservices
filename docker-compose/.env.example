# -----------------------------------------------------------------------------
# issue-tracker-microservices — docker-compose env overrides
# Copy to `.env` in this directory to override defaults.
# -----------------------------------------------------------------------------

# Database (Postgres 16)
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_PORT=5433

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_PORT=5673
RABBITMQ_MGMT_PORT=15673

# Zipkin distributed tracing
ZIPKIN_PORT=9411

# Service registry + configuration
DISCOVERY_PORT=8761

# Business services (through the gateway, you usually don't hit these directly)
USER_PORT=9093
PROJECT_PORT=9091
TASK_PORT=9092
NOTIFICATION_PORT=9094

# API gateway (UI talks to this)
GATEWAY_PORT=8762

# JWT signing secret — must be at least 32 characters for HS256.
# In production override with a long random string, e.g. `openssl rand -hex 48`.
JWT_SECRET=issue-tracker-jwt-secret-key-must-be-at-least-256-bits-long-for-hs256

# Monitoring (Grafana is on 3030 so the UI can have 3000)
GRAFANA_PORT=3030
